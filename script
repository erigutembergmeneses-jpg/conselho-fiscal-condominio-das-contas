    // Capa e Contracapa
    'qr-capa1': 'https://autor.condominioeficiente.com/apresentacao-video',
    'qr-capa2': 'https://demo.checklistcondominial.app/demo',
    'qr-capa3': 'https://suporte.condominioeficiente.com/canal-duvidas',
    
    // Capítulo 4 - Conselho Fiscal
    'qr-cap4-1': 'https://modelos.condominiolegal.com/regimento-conselho.docx',
    'qr-cap4-2': 'https://ferramentas.condominio.app/quorum-calculator',
    'qr-cap4-3': 'https://sim.condominiolegal.com/responsabilidade-civil',
    
    // Capítulo 5 - Prestação de Contas
    'qr-cap5-1': 'https://planilhas.condominioeficiente.com/conciliacao-bancaria.xlsx',
    'qr-cap5-2': 'https://tutoriais.condominio.app/como-ler-balancete',
    'qr-cap5-3': 'https://checklist.condominiolegal.com/auditoria-interativa',
    
    // Capítulo 7 - Áreas-Chave
    'qr-cap7-1': 'https://dashboard.condominioesg.com/demo',
    'qr-cap7-2': 'https://eficiencia.condominio.app/roi-energia',
    'qr-cap7-3': 'https://mapaderiscos.condominiolegal.com/interativo',
    
    // Anexos Operacionais
    'qr-anexo1': 'https://biblioteca.condominioeficiente.com/modelos-editaveis',
    'qr-anexo2': 'https://forum.condominiolegal.com/exclusivo-leitores',
    'qr-anexo3': 'https://atualizacoes.condominio.app/legislacao-tempo-real'
};

// Função para gerar QR Code em um elemento específico
function generateQRCode(elementId, url) {
    const element = document.getElementById(elementId);
    if (!element) return false;
    
    element.innerHTML = '';
    const qrDiv = document.createElement('div');
    qrDiv.classList.add('qr-code-element');
    element.appendChild(qrDiv);
    
    try {
        new QRCode(qrDiv, {
            text: url,
            width: 120,
            height: 120,
            colorDark: "#1a2c3e",
            colorLight: "#ffffff",
            correctLevel: QRCode.CorrectLevel.M
        });
        return true;
    } catch (error) {
        console.error(`Erro ao gerar QR Code para ${elementId}:`, error);
        qrDiv.innerHTML = `<div style="text-align:center; font-size:12px;">
            <i class="fas fa-exclamation-triangle"></i><br>
            <a href="${url}" target="_blank" style="color: #f5a623;">Acessar link</a>
        </div>`;
        return false;
    }
}

// Função para configurar os botões de link
function setupButtons() {
    const allButtons = document.querySelectorAll('.link-demo');
    allButtons.forEach(button => {
        // Tenta encontrar o URL através do card pai
        const parentCard = button.closest('.qr-card');
        if (parentCard) {
            const resourceUrl = parentCard.getAttribute('data-resource');
            if (resourceUrl) {
                button.setAttribute('href', resourceUrl);
                button.setAttribute('target', '_blank');
                button.setAttribute('rel', 'noopener noreferrer');
            }
        }
        
        // Adiciona tracking de clique (opcional)
        button.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if (href && href !== '#') {
                console.log(`[Analytics] Acesso ao recurso: ${href}`);
                // Aqui você pode integrar com Google Analytics ou similar
                if (typeof gtag !== 'undefined') {
                    gtag('event', 'click', {
                        'event_category': 'resource_access',
                        'event_label': href
                    });
                }
            }
        });
    });
}

// Função para adicionar tooltips informativos
function addTooltips() {
    const resources = document.querySelectorAll('.resource-desc');
    resources.forEach((resource, index) => {
        const parentCard = resource.closest('.qr-card');
        if (parentCard) {
            const url = parentCard.getAttribute('data-resource');
            if (url) {
                resource.setAttribute('data-tooltip', `🔗 ${url.substring(0, 50)}...`);
            }
        }
    });
}

// Função para adicionar indicador de "carregando" enquanto gera QR Codes
function showLoadingState() {
    const placeholders = document.querySelectorAll('.qr-placeholder');
    placeholders.forEach(placeholder => {
        placeholder.innerHTML = '<div style="text-align:center; padding:20px;"><i class="fas fa-spinner fa-pulse"></i> Gerando QR Code...</div>';
    });
}

// Função principal de inicialização
function init() {
    console.log('🚀 Inicializando recursos do livro "Conselho Fiscal: Com Domínio das Contas"');
    
    // Mostra estado de loading
    showLoadingState();
    
    // Gera QR Codes baseados no mapeamento
    setTimeout(() => {
        let successCount = 0;
        let failCount = 0;
        
        for (const [elementId, url] of Object.entries(RESOURCE_CONFIG)) {
            const success = generateQRCode(elementId, url);
            if (success) {
                successCount++;
            } else {
                failCount++;
            }
        }
        
        console.log(`✅ QR Codes gerados: ${successCount} sucesso, ${failCount} falhas`);
        
        // Também gera QR Codes para cards que podem ter URLs customizadas
        const customCards = document.querySelectorAll('.qr-card[data-resource]');
        customCards.forEach(card => {
            const resourceUrl = card.getAttribute('data-resource');
            const placeholder = card.querySelector('.qr-placeholder');
            if (placeholder && placeholder.innerHTML.includes('Gerando QR Code')) {
                const qrDiv = document.createElement('div');
                qrDiv.classList.add('qr-code-element');
                placeholder.innerHTML = '';
                placeholder.appendChild(qrDiv);
                try {
                    new QRCode(qrDiv, {
                        text: resourceUrl,
                        width: 120,
                        height: 120,
                        colorDark: "#1a2c3e",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.M
                    });
                } catch(e) {
                    qrDiv.innerHTML = `<a href="${resourceUrl}" target="_blank">🔗 Link direto</a>`;
                }
            }
        });
    }, 100);
    
    // Configura botões
    setupButtons();
    
    // Adiciona tooltips
    addTooltips();
    
    // Adiciona evento de fallback para links quebrados
    window.addEventListener('online', () => {
        console.log('🌐 Conexão restaurada - recursos disponíveis');
    });
}

// Função para copiar link do QR Code (feature extra)
window.copyQRCodeLink = function(elementId) {
    const url = RESOURCE_CONFIG[elementId];
    if (url) {
        navigator.clipboard.writeText(url).then(() => {
            // Feedback visual
            const toast = document.createElement('div');
            toast.textContent = '✅ Link copiado!';
            toast.style.cssText = `
                position: fixed;
                bottom: 20px;
                right: 20px;
                background: #0b2b3b;
                color: #f5a623;
                padding: 12px 20px;
                border-radius: 8px;
                z-index: 9999;
                font-weight: bold;
                animation: fadeInUp 0.3s ease;
            `;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2000);
        }).catch(() => {
            alert('Clique no botão para acessar o link diretamente');
        });
    }
};

// Inicializa quando o DOM estiver pronto
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}

// Service Worker para PWA (opcional - pode ser implementado posteriormente)
if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(err => {
        console.log('Service Worker não registrado:', err);
    });
}
